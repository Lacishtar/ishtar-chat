{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://youtube-overlay-studio/schema/bubble.schema.json",
  "title": "style.bubble",
  "type": "object",
  "properties": {
    "type": { "type": "string", "enum": ["color", "gradient", "image"] },
    "image": {
      "oneOf": [
        { "type": ["string", "null"] },
        {
          "type": "object",
          "properties": { "asset": { "type": "string" } },
          "required": ["asset"],
          "additionalProperties": false
        }
      ]
    },
    "slice": { "$ref": "#/$defs/edgeInsets" },
    "padding": { "$ref": "#/$defs/edgeInsets" },
    "scale": { "type": "number", "minimum": 0.25, "maximum": 3 },
    "gradient": { "$ref": "#/$defs/gradient" }
  },
  "additionalProperties": false,
  "$defs": {
    "edgeInsets": {
      "type": "object",
      "properties": {
        "top": { "type": "number", "minimum": 0 },
        "right": { "type": "number", "minimum": 0 },
        "bottom": { "type": "number", "minimum": 0 },
        "left": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "gradient": {
      "type": "object",
      "properties": {
        "angle": { "type": "number" },
        "from": { "type": "string" },
        "to": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
